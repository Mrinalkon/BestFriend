# Copy this file to .env and fill in your API keys

# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# (Optional) Get your key at: https://elevenlabs.io/ for premium voice quality
# If left empty, the app will use the browser's built-in voice
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
